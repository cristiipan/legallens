# --- Cohere ---
# Leave blank (or set to "mock") to use the local sentence-transformers
# embedder and skip live LLM calls. Useful for clones without a Cohere account.
COHERE_API_KEY=
COHERE_MODEL=command-r-plus

# --- Pinecone ---
# Leave blank to use the local on-disk numpy vector store (data/vectors/).
PINECONE_API_KEY=
PINECONE_INDEX_NAME=legallens-clauses
PINECONE_ENVIRONMENT=us-east-1-aws

# Where the local fallback vector store lives.
LOCAL_VECTOR_ROOT=./data/vectors

# --- PostgreSQL ---
DATABASE_URL=postgresql+asyncpg://legallens:legallens@localhost:5432/legallens

# --- Redis Sentinel ---
# Three Sentinels on the docker-compose network. Use `localhost:26379,...`
# if running scripts on the host against the dockerized services.
REDIS_SENTINELS=localhost:26379,localhost:26380,localhost:26381
REDIS_MASTER_NAME=legallens-master

# --- Logging ---
LOG_LEVEL=INFO
